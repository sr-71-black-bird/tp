<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints percentWidth="55" minWidth="10"/>
      <ColumnConstraints percentWidth="45" minWidth="10" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0">
      <padding>
        <Insets top="5" right="5" bottom="5" left="15" />
      </padding>
      <HBox spacing="0.5" alignment="CENTER_LEFT">
        <Label fx:id="id" styleClass="cell_big_label">
          <minWidth>
            <!-- Ensures that the label text is never truncated -->
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" wrapText="true" HBox.hgrow="ALWAYS"/>
      </HBox>
      <FlowPane fx:id="tags" />
      <HBox spacing="6" alignment="CENTER_LEFT">
        <FontIcon iconLiteral="fas-phone" iconSize="12" iconColor="#3c2f2f" scaleX="-1"/>
        <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" wrapText="true" HBox.hgrow="ALWAYS" />
      </HBox>
      <HBox spacing="6" alignment="CENTER_LEFT">
        <FontIcon iconLiteral="fas-map-marker-alt" iconSize="12" iconColor="#3c2f2f" />
        <Label fx:id="address" styleClass="cell_small_label" text="\$address" wrapText="true" HBox.hgrow="ALWAYS" />
      </HBox>
      <HBox spacing="6" alignment="CENTER_LEFT">
        <FontIcon iconLiteral="fas-envelope" iconSize="12" iconColor="#3c2f2f" />
        <Label fx:id="email" styleClass="cell_small_label" text="\$email" wrapText="true" HBox.hgrow="ALWAYS" />
      </HBox>
    </VBox>
    <ScrollPane styleClass="pet-scroll-pane" fitToWidth="true" fitToHeight="true"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" GridPane.columnIndex="1">
      <padding>
        <Insets top="5" right="5" bottom="5" left="5" />
      </padding>
      <VBox fx:id="petsContainer" spacing="4" />
    </ScrollPane>
  </GridPane>
</HBox>
