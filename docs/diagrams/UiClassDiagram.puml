@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor UI_COLOR_T4
skinparam classBackgroundColor UI_COLOR

left to right direction

package UI <<Rectangle>>{
Class "<<interface>>\nUi" as Ui
Class "{abstract}\nUiPart" as UiPart
Class UiManager
Class MainWindow
Class HelpWindow
Class ResultDisplay
Class OwnerListPanel
Class OwnerCard
Class StatusBarFooter
Class CommandBox
Class SessionListPanel
Class SessionCard
Class ServiceListPanel
}

package Model <<Rectangle>> {
Class HiddenModel #FFFFFF
}

package Logic <<Rectangle>> {
Class HiddenLogic #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Ui

UiManager .|> Ui
UiManager --> "1" MainWindow
MainWindow *--> "1" CommandBox
MainWindow *--> "1" ResultDisplay
MainWindow *--> "1" OwnerListPanel
MainWindow *--> "1" StatusBarFooter
MainWindow *--> "1" SessionListPanel
MainWindow *--> "1" ServiceListPanel
MainWindow --> "0..1" HelpWindow

OwnerListPanel --> "*" OwnerCard
SessionListPanel --> "*" SessionCard

note right of OwnerCard : renders pets inline

ResultDisplay --|> UiPart
CommandBox --|> UiPart
OwnerListPanel --|> UiPart
OwnerCard --|> UiPart
StatusBarFooter --|> UiPart
HelpWindow --|> UiPart
SessionListPanel --|> UiPart
SessionCard --|> UiPart
ServiceListPanel --|> UiPart
MainWindow --|> UiPart

OwnerCard ..> Model
UiManager --> Logic
MainWindow --> Logic
@enduml
